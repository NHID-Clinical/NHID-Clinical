import sqlite3
def _get_conn():
        return sqlite3.connect("nhid_events.db", check_same_thread=False)
        
def get_cached_llm_response(cache_key: str):
            conn = _get_conn()
                cur = conn.cursor()
                    cur.execute(
                            "SELECT response FROM llm_cache WHERE cache_key = ?",
                                    (cache_key,)
                                        )
                                            row = cur.fetchone()
                                                conn.close()
                                                    return row[0] if row else None
                                                    
